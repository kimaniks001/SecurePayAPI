# =============================================================================
# SecurePay API — Local Development Environment (PLACEHOLDERS ONLY)
# =============================================================================
#
# WARNING:
# - Do NOT use these values in staging or production.
# - Do NOT commit a real .env file to version control.
# - Choice Bank credentials must NEVER appear in committed files.
# - Production secrets belong in an approved secrets manager.
#
# Copy this file to .env for local development:
#   cp .env.example .env
# =============================================================================

# PostgreSQL (local docker-compose)
POSTGRES_DB=securepay_local
POSTGRES_USER=securepay_local
POSTGRES_PASSWORD=local_dev_only_change_me
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Redis-compatible cache (local docker-compose)
REDIS_PORT=6379
REDIS_HOST=localhost

# Application
ENVIRONMENT=local
LOG_LEVEL=debug
APP_PORT=8080
MANAGEMENT_PORT=8081
SPRING_PROFILES_ACTIVE=local
